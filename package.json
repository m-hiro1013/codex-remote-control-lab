{
  "name": "codex-remote-control-lab",
  "version": "1.0.0",
  "description": "Local lab for OpenAI Codex CLI remote-control and app-server experiments.",
  "private": false,
  "type": "commonjs",
  "scripts": {
    "version:codex": "codex --version",
    "help:remote-control": "codex remote-control --help",
    "server:ws": "node scripts/start-codex-app-server.js",
    "probe:ws": "node scripts/probe-ws.js",
    "postinstall": "node scripts/ensure-pty-helper-perms.js",
    "phone": "node scripts/start-phone.js",
    "build:ui": "node scripts/build-ui.mjs",
    "screenshots:readme": "node scripts/capture-readme-screenshots.js",
    "test": "node --test scripts/*.test.js",
    "check": "node scripts/build-ui.mjs --check && node --check scripts/start-phone.js && node --check scripts/probe-ws.js && node --check public/main.js",
    "docs:dev": "vitepress dev docs",
    "docs:build": "vitepress build docs",
    "docs:preview": "vitepress preview docs"
  },
  "keywords": [
    "codex",
    "remote-control",
    "app-server",
    "websocket",
    "phone-bridge",
    "local-first"
  ],
  "author": "Sunwood AI Labs",
  "license": "ISC",
  "devDependencies": {
    "@openai/codex": "^0.130.0",
    "esbuild": "^0.28.0",
    "playwright": "^1.59.1",
    "vitepress": "^1.6.4",
    "ws": "^8.20.0"
  },
  "dependencies": {
    "@fortawesome/free-solid-svg-icons": "^7.2.0",
    "@xterm/addon-fit": "^0.11.0",
    "@xterm/xterm": "^6.0.0",
    "lucide-react": "^1.14.0",
    "node-pty": "^1.1.0",
    "react": "^18.3.1",
    "react-dom": "^18.3.1"
  }
}
