# Codex Remote Control Lab example environment.
# Copy this file to .env for local use. Do not commit your real .env.

# Browser bridge and Codex app-server endpoints.
PHONE_UI_PORT=45214
CODEX_APP_SERVER_PORT=45213
# CODEX_APP_SERVER_URL=ws://127.0.0.1:45213
# CODEX_APP_SERVER_SOCK=/Users/admin/.codex/app-server-control/app-server-control.sock

# Codex defaults for new turns.
# Defaults to this repository root when unset.
# CODEX_WORKDIR=/path/to/your/project
CODEX_MODEL=gpt-5.4
CODEX_HISTORY_SYNC=1

# Token handling.
# Leave these commented for the default token-protected LAN bridge.
# Enable PHONE_DEBUG_NO_TOKEN for tokenless localhost-only debugging.
# Add PHONE_DEBUG_BIND=lan only for tokenless debugging on a trusted private LAN.
# PHONE_TOKEN=choose-your-own-token
# PHONE_DEBUG_NO_TOKEN=1
# PHONE_DEBUG_BIND=lan

# Optional startup notifications. Keep targets private because URLs can grant access.
# PHONE_NTFY_TOPIC=your-private-topic
# PHONE_NTFY_SERVER=https://ntfy.sh
# PHONE_NTFY_TOKEN=optional-ntfy-token
# PHONE_PUSHOVER_TOKEN=app-token
# PHONE_PUSHOVER_USER=user-key
# PHONE_PUSHOVER_DEVICE=iphone
# PHONE_DISCORD_WEBHOOK_URL=https://discord.com/api/webhooks/...
PHONE_NOTIFY_TIMEOUT_MS=5000
